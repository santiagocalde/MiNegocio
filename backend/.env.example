# ─────────────────────────────────────────────────────────────
# NovaStock - Variables de entorno
# Copiar este archivo a .env y completar los valores reales
# NUNCA commitear el archivo .env al repositorio
# ─────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════
# JWT (OBLIGATORIO)
# ═══════════════════════════════════════════════════════════
# En produccion, generar con: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️  Si APP_ENV=production y JWT_SECRET no se cambia, el servidor NO arranca.
JWT_SECRET=novastock-dev-secret-CAMBIAR-EN-PRODUCCION-2026

# ═══════════════════════════════════════════════════════════
# POSTGRESQL (SaaS layer: auth, plans, testimonials, billing)
# ═══════════════════════════════════════════════════════════
PG_HOST=localhost
PG_PORT=5432
PG_USER=novastock
PG_PASSWORD=1234
PG_DATABASE=novastock

# ═══════════════════════════════════════════════════════════
# BASE DE DATOS CLOUD (OPCIONAL - sync de datos operativos)
# ═══════════════════════════════════════════════════════════
# Si esta vacio, el sistema opera 100% local (SQLite).
# Si se define, apunta a PostgreSQL para sync cloud.
# Formato: postgresql://usuario:password@host:5432/nombre_db
DATABASE_URL=

# ═══════════════════════════════════════════════════════════
# MERCADO PAGO (OPCIONAL - para pagos QR y suscripciones)
# ═══════════════════════════════════════════════════════════
# Obtener en: https://www.mercadopago.com.ar/developers/panel
MP_ACCESS_TOKEN=
MP_COLLECTOR_ID=

# ═══════════════════════════════════════════════════════════
# RESEND (OPCIONAL - para envio de emails)
# ═══════════════════════════════════════════════════════════
# Obtener en: https://resend.com
# Se usa para: formulario de contacto, recuperacion de contrasena
RESEND_API_KEY=

# ═══════════════════════════════════════════════════════════
# ENTORNO
# ═══════════════════════════════════════════════════════════
# production | development
# En production: valida que JWT_SECRET no sea el default, activa logs mas estrictos.
APP_ENV=development